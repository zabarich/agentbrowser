{
  "name": "agentbrowser",
  "version": "0.1.0",
  "description": "A TypeScript-native autonomous browser agent for Node.js, inspired by browser-use. Give an LLM a task and a browser — it figures out the rest.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "browser-agent",
    "autonomous",
    "playwright",
    "llm",
    "ai",
    "web-automation",
    "anthropic",
    "openai",
    "browser-use"
  ],
  "author": "zabarich",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zabarich/agentbrowser.git"
  },
  "bugs": {
    "url": "https://github.com/zabarich/agentbrowser/issues"
  },
  "homepage": "https://github.com/zabarich/agentbrowser#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^6.32.0",
    "playwright": "^1.50.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
